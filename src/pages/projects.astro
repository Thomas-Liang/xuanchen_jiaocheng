---
import Layout from '../layouts/Layout.astro';
import PageLayout from '../components/PageLayout.astro';
import Card from '../components/Card.astro';
import { getAllProjects } from '../lib/auth';

const basePath = '/xuanchen_content';
const projects = getAllProjects();
---

<Layout 
  title="开源项目"
  description="泫晨云栖的开源项目列表，展示我们开发和维护的技术项目"
>
  <PageLayout 
    badge="💻 开源项目"
    badgeColor="violet"
    subtitle="这里展示了我们开发和维护的技术项目，欢迎 Star 和 Fork"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <Card href={project.url} padding="md">
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-start gap-3">
              <span class="text-4xl">{project.icon || '📦'}</span>
              <div>
                <h2 class="text-xl font-bold text-slate-800 dark:text-slate-200">
                  {project.name}
                </h2>
              </div>
            </div>
            <svg class="w-6 h-6 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </div>
          <p class="text-slate-500 dark:text-slate-400 mb-4">{project.description}</p>
          <span class="text-sm text-blue-600 dark:text-blue-400 font-medium">访问 GitHub →</span>
        </Card>
      ))}
    </div>

    {projects.length === 0 && (
      <div class="text-center py-16">
        <div class="text-6xl mb-4">📦</div>
        <h2 class="text-xl font-semibold text-slate-700 dark:text-slate-300 mb-2">暂无开源项目</h2>
        <p class="text-slate-500 dark:text-slate-400">开源项目即将上线</p>
      </div>
    )}

    <div class="mt-12 text-center">
      <div class="inline-block p-8 bg-gradient-to-r from-violet-50 to-purple-50 dark:from-slate-800 dark:to-slate-700 rounded-2xl">
        <h3 class="text-lg font-semibold text-slate-800 dark:text-slate-200 mb-2">贡献项目</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">如果你有好的项目想要分享，欢迎联系我们</p>
        <a href="mailto:xuanchenyiran@163.com" class="inline-flex items-center gap-2 px-4 py-2 bg-violet-600 text-white text-sm rounded-lg hover:bg-violet-700 transition-colors">
          联系我们
        </a>
      </div>
    </div>
  </PageLayout>
</Layout>
