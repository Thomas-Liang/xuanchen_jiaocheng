---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { getTutorialBySlug } from '../../../lib/tutorial';

const { slug } = Astro.params;
const tutorial = slug ? getTutorialBySlug(slug) : null;
const basePath = '/xuanchen_content';

if (!tutorial) {
  return Astro.redirect(`${basePath}/tutorials`);
}
---

<Layout title="编辑教程 - 泫晨云栖">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6 text-slate-800 dark:text-slate-200">编辑教程</h1>
    <form id="tutorialForm" class="space-y-6 bg-white dark:bg-slate-800 p-6 rounded-2xl border border-slate-200 dark:border-slate-700">
      <input type="hidden" name="slug" value={tutorial.slug} />
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">标题 *</label>
        <input type="text" name="title" required value={tutorial.title} class="w-full px-4 py-2 border border-slate-200 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">描述 *</label>
        <input type="text" name="description" required value={tutorial.description} class="w-full px-4 py-2 border border-slate-200 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">作者 *</label>
        <input type="text" name="author" required value={tutorial.author} class="w-full px-4 py-2 border border-slate-200 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">标签 (逗号分隔)</label>
        <input type="text" name="tags" value={tutorial.tags.join(', ')} class="w-full px-4 py-2 border border-slate-200 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">封面图</label>
        <input type="file" id="coverInput" accept="image/*" class="mb-2 block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
        <input type="hidden" name="coverImage" id="coverImageUrl" value={tutorial.coverImage || ''} />
        <div id="coverPreview" class={tutorial.coverImage ? 'w-48 h-32 bg-slate-200 dark:bg-slate-600 rounded-lg overflow-hidden' : 'hidden w-48 h-32 bg-slate-200 dark:bg-slate-600 rounded-lg overflow-hidden'}>
          <img id="coverPreviewImg" src={tutorial.coverImage || ''} class="w-full h-full object-cover" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">视频链接</label>
        <input type="url" name="videoUrl" value={tutorial.videoUrl || ''} class="w-full px-4 py-2 border border-slate-200 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">内容 *</label>
        <textarea name="content" required rows="15" class="w-full px-4 py-2 border border-slate-200 dark:border-slate-600 rounded-lg bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200 font-mono">{tutorial.content}</textarea>
      </div>
      <div class="flex gap-4">
        <button type="submit" class="px-6 py-2.5 bg-gradient-to-r from-blue-600 to-violet-600 text-white font-medium rounded-lg hover:shadow-lg hover:shadow-blue-500/25 transition-all">
          保存
        </button>
        <a href={`${basePath}/admin`} class="px-6 py-2.5 border border-slate-200 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
          取消
        </a>
      </div>
    </form>
  </div>
  
  <script>
    const form = document.getElementById('tutorialForm');
    const coverInput = document.getElementById('coverInput') as HTMLInputElement;
    const coverImageUrl = document.getElementById('coverImageUrl') as HTMLInputElement;
    const coverPreview = document.getElementById('coverPreview');
    const coverPreviewImg = document.getElementById('coverPreviewImg') as HTMLImageElement;
    let uploadedCoverUrl = '';
    
    coverInput?.addEventListener('change', async () => {
      const file = coverInput.files?.[0];
      if (!file) return;
      
      const formData = new FormData();
      formData.append('file', file);
      
      try {
        const res = await fetch('/xuanchen_content/api/upload', {
          method: 'POST',
          body: formData,
        });
        
        const data = await res.json();
        
        if (data.url) {
          uploadedCoverUrl = data.url;
          coverImageUrl.value = data.url;
          coverPreviewImg.src = data.url;
          coverPreview?.classList.remove('hidden');
        } else if (data.error) {
          alert('上传失败: ' + data.error);
        }
      } catch (error) {
        console.error('Upload failed:', error);
        alert('上传失败，请重试');
      }
    });
    
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const coverImageInput = document.querySelector('input[name="coverImage"]') as HTMLInputElement;
      if (coverImageInput && uploadedCoverUrl) {
        coverImageInput.value = uploadedCoverUrl;
      }
      
      const formData = new FormData(form as HTMLFormElement);
      
      try {
        const response = await fetch('/xuanchen_content/api/tutorials/edit', {
          method: 'POST',
          body: formData,
        });
        
        const result = await response.json();
        
        if (response.ok) {
          alert('保存成功！');
          window.location.href = '/xuanchen_content/admin';
        } else {
          alert('保存失败: ' + (result.error || '未知错误'));
        }
      } catch (error) {
        console.error(error);
        alert('保存失败');
      }
    });
  </script>
</Layout>
