---
export const prerender = false;
---
<!doctype html>
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>新建教程 - 泫晨云栖</title>
</head>
<body class="min-h-screen bg-slate-50">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold mb-6">新建教程</h1>
    <form id="tutorialForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1">标题 *</label>
        <input type="text" name="title" required class="w-full px-4 py-2 border rounded-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">描述 *</label>
        <input type="text" name="description" required class="w-full px-4 py-2 border rounded-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">作者 *</label>
        <input type="text" name="author" required class="w-full px-4 py-2 border rounded-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">标签 (逗号分隔)</label>
        <input type="text" name="tags" placeholder="React, Next.js, 教程" class="w-full px-4 py-2 border rounded-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">封面图</label>
        <input type="file" id="coverInput" accept="image/*" class="mb-2" />
        <input type="hidden" name="coverImage" id="coverImageUrl" />
        <div id="coverPreview" class="hidden w-48 h-32 bg-slate-200 rounded-lg overflow-hidden">
          <img id="coverPreviewImg" class="w-full h-full object-cover" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">视频链接</label>
        <input type="url" name="videoUrl" class="w-full px-4 py-2 border rounded-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">内容 *</label>
        <textarea name="content" required rows="15" class="w-full px-4 py-2 border rounded-lg font-mono"></textarea>
      </div>
      <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        保存
      </button>
    </form>
  </div>
  
  <script>
    const form = document.getElementById('tutorialForm');
    const coverInput = document.getElementById('coverInput') as HTMLInputElement;
    const coverImageUrl = document.getElementById('coverImageUrl') as HTMLInputElement;
    const coverPreview = document.getElementById('coverPreview');
    const coverPreviewImg = document.getElementById('coverPreviewImg') as HTMLImageElement;
    let uploadedCoverUrl = '';
    
    coverInput?.addEventListener('change', async () => {
      const file = coverInput.files?.[0];
      if (!file) return;
      
      const formData = new FormData();
      formData.append('file', file);
      
      const res = await fetch('/xuanchen_content/api/upload', {
        method: 'POST',
        body: formData,
      });
      
      const data = await res.json();
      if (data.url) {
        uploadedCoverUrl = data.url;
        coverImageUrl.value = data.url;
        coverPreviewImg.src = data.url;
        coverPreview?.classList.remove('hidden');
      }
    });
    
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (uploadedCoverUrl) {
        (form.querySelector('input[name="coverImage"]') as HTMLInputElement).value = uploadedCoverUrl;
      }
      
      const formData = new FormData(form as HTMLFormElement);
      const res = await fetch('/xuanchen_content/api/tutorials/create', {
        method: 'POST',
        body: formData,
      });
      
      if (res.ok) {
        alert('保存成功！');
        window.location.href = '/xuanchen_content/admin';
      } else {
        const data = await res.json();
        alert('保存失败: ' + (data.error || '未知错误'));
      }
    });
  </script>
</body>
</html>
