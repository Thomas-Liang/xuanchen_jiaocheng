---
import Layout from '../../../layouts/Layout.astro';
import { getAllUsers, getFollowerCount, getFollowingCount, isFollowing, getFollowers, getFollowing } from '../../../lib/auth';

const basePath = '/xuanchen_content';

export const prerender = false;

const { username } = Astro.params;
const currentUser = Astro.cookies.get('username')?.value;

if (!username) {
  return Astro.redirect(`${basePath}/users`);
}

const user = getAllUsers().find(u => u.username === username);
if (!user) {
  return Astro.redirect(`${basePath}/users`);
}

const followerCount = getFollowerCount(username);
const followingCount = getFollowingCount(username);
const followers = getFollowers(username);
const following = getFollowing(username);
const isFollowingUser = currentUser ? isFollowing(currentUser, username) : false;
const isOwnProfile = currentUser === username;
---

<Layout title={`${username} - 泫晨云栖`}>
  <div class="min-h-screen bg-gradient-to-br from-pink-50 via-white to-violet-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 py-12">
    <div class="max-w-2xl mx-auto px-4">
      <!-- Profile Card -->
      <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-xl border border-slate-200 dark:border-slate-700 overflow-hidden mb-8">
        <div class="h-24 bg-gradient-to-r from-pink-400 via-rose-300 to-violet-400"></div>
        <div class="px-6 pb-6">
          <div class="flex flex-col items-center -mt-12">
            <img 
              src={user.avatar ? `${basePath}${user.avatar}` : `${basePath}/avatars/default.svg`}
              alt={username}
              class="w-24 h-24 rounded-full object-cover ring-4 ring-white dark:ring-slate-800 shadow-xl"
            />
            <h1 class="mt-4 text-2xl font-bold text-slate-800 dark:text-slate-200 flex items-center gap-2">
              {username}
              {username === 'admin' && (
                <span class="px-2 py-1 text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full">
                  管理员
                </span>
              )}
            </h1>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
              加入于 {new Date(user.created_at).toLocaleDateString('zh-CN')}
            </p>
            
            <!-- Stats -->
            <div class="flex gap-8 mt-6">
              <div class="text-center">
                <div class="text-2xl font-bold text-blue-500">{followerCount}</div>
                <div class="text-sm text-slate-500">粉丝</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-pink-500">{followingCount}</div>
                <div class="text-sm text-slate-500">关注</div>
              </div>
            </div>
            
            <!-- Follow Button -->
            {currentUser && !isOwnProfile && (
              <button 
                id="followBtn"
                class="mt-6 px-8 py-2.5 rounded-xl font-medium transition-all ${
                  isFollowingUser 
                    ? 'bg-slate-100 dark:bg-slate-700 text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-600' 
                    : 'bg-gradient-to-r from-pink-500 to-violet-500 text-white hover:shadow-lg hover:shadow-pink-500/25'
                }"
                data-follower={currentUser}
                data-following={username}
                data-is-following={isFollowingUser}
              >
                {isFollowingUser ? '已关注' : '+ 关注'}
              </button>
            )}
            
            {currentUser && isOwnProfile && (
              <a 
                href={`${basePath}/profile`}
                class="mt-6 px-8 py-2.5 rounded-xl font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-all inline-block text-center"
              >
                编辑资料
              </a>
            )}
          </div>
        </div>
      </div>
      
      <!-- Tabs -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg border border-slate-200 dark:border-slate-700 overflow-hidden">
        <div class="flex border-b border-slate-200 dark:border-slate-700">
          <button class="tab-btn flex-1 px-4 py-4 text-sm font-medium text-pink-600 bg-pink-50/50 dark:bg-pink-900/20 text-center" data-tab="followers">
            粉丝 ({followerCount})
          </button>
          <button class="tab-btn flex-1 px-4 py-4 text-sm font-medium text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 text-center" data-tab="following">
            关注 ({followingCount})
          </button>
        </div>
        
        <!-- Followers -->
        <div id="tab-followers" class="tab-content p-4">
          {followers.length > 0 ? (
            <div class="space-y-3">
              {followers.map(f => (
                <a href={`${basePath}/user/${f.username}`} class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                  <img 
                    src={f.avatar ? `${basePath}${f.avatar}` : `${basePath}/avatars/default.svg`}
                    alt={f.username}
                    class="w-10 h-10 rounded-full object-cover"
                  />
                  <span class="font-medium text-slate-800 dark:text-slate-200">{f.username}</span>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-10 text-slate-400">
              <p class="text-3xl mb-2">👥</p>
              <p>还没有粉丝</p>
            </div>
          )}
        </div>
        
        <!-- Following -->
        <div id="tab-following" class="tab-content p-4 hidden">
          {following.length > 0 ? (
            <div class="space-y-3">
              {following.map(f => (
                <a href={`${basePath}/user/${f.username}`} class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                  <img 
                    src={f.avatar ? `${basePath}${f.avatar}` : `${basePath}/avatars/default.svg`}
                    alt={f.username}
                    class="w-10 h-10 rounded-full object-cover"
                  />
                  <span class="font-medium text-slate-800 dark:text-slate-200">{f.username}</span>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-10 text-slate-400">
              <p class="text-3xl mb-2">➡️</p>
              <p>还没有关注任何人</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
  
  <script define:vars={{ basePath }}>
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('text-pink-600', 'bg-pink-50/50', 'dark:bg-pink-900/20');
          b.classList.add('text-slate-500');
        });
        btn.classList.remove('text-slate-500');
        btn.classList.add('text-pink-600', 'bg-pink-50/50', 'dark:bg-pink-900/20');
        
        document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
        document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
      });
    });
    
    const followBtn = document.getElementById('followBtn');
    if (followBtn) {
      followBtn.addEventListener('click', async () => {
        const follower = followBtn.dataset.follower;
        const following = followBtn.dataset.following;
        const isFollowing = followBtn.dataset.isFollowing === 'true';
        const action = isFollowing ? 'unfollow' : 'follow';
        
        try {
          const res = await fetch(`${basePath}/api/follow`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ follower, following, action })
          });
          
          const data = await res.json();
          
          if (data.success) {
            location.reload();
          }
        } catch (err) {
          console.error(err);
        }
      });
    }
  </script>
</Layout>
