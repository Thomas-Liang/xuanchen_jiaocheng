---
import Layout from '../layouts/Layout.astro';
import PageLayout from '../components/PageLayout.astro';
import Card from '../components/Card.astro';
import { getAllWorkflows } from '../lib/auth';

const basePath = '/xuanchen_content';
const workflowsData = getAllWorkflows();
---

<Layout 
  title="工作流"
  description="泫晨云栖的工作流模板，帮助你自动化重复性工作，提升开发效率"
>
  <PageLayout 
    badge="⚡ 工作流"
    badgeColor="amber"
    subtitle="发现并使用高效的工作流程，提升团队协作效率"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {workflowsData.map((workflow) => (
        <Card href={workflow.url} padding="md">
          <div class="flex items-start justify-between mb-4">
            <span class="text-4xl">{workflow.icon || '⚡'}</span>
            {!workflow.url && (
              <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full text-xs">
                即将上线
              </span>
            )}
          </div>
          <h2 class="text-xl font-bold text-slate-800 dark:text-slate-200 mb-2">
            {workflow.name}
          </h2>
          <p class="text-slate-500 dark:text-slate-400 mb-4 text-sm">{workflow.description}</p>
          <div class="flex flex-wrap gap-2">
            {(workflow.tags || '').split(',').filter((t: string) => t.trim()).map((tag: string) => (
              <span class="px-2 py-1 bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded-full text-xs">
                {tag.trim()}
              </span>
            ))}
          </div>
          {workflow.url && (
            <span class="text-sm text-blue-600 dark:text-blue-400 font-medium mt-4 block">访问工作流 →</span>
          )}
        </Card>
      ))}
    </div>

    {workflowsData.length === 0 && (
      <div class="text-center py-16">
        <div class="text-6xl mb-4">⚡</div>
        <h2 class="text-xl font-semibold text-slate-700 dark:text-slate-300 mb-2">工作流即将上线</h2>
        <p class="text-slate-500 dark:text-slate-400">更多工作流模板正在准备中</p>
      </div>
    )}
  </PageLayout>
</Layout>
