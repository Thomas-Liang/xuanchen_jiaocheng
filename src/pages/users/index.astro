---
import Layout from '../../layouts/Layout.astro';
import { getAllUsers, getFollowerCount, getFollowingCount, isFollowing } from '../../lib/auth';

const username = Astro.cookies.get('username')?.value;
const basePath = '/xuanchen_content';

if (username !== 'admin') {
  return Astro.redirect(`${basePath}/`);
}

const users = getAllUsers();
const usersWithCounts = users.map(user => ({
  ...user,
  followerCount: getFollowerCount(user.username),
  followingCount: getFollowingCount(user.username),
  isFollowing: username ? isFollowing(username, user.username) : false
}));

const currentUserFollowers = username ? getFollowerCount(username) : 0;
const currentUserFollowing = username ? getFollowingCount(username) : 0;
---

<Layout title="用户 - 泫晨云栖">
  <div class="min-h-screen bg-gradient-to-br from-pink-50 via-white to-violet-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900 py-12">
    <div class="max-w-4xl mx-auto px-4">
      
      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-3xl font-bold bg-gradient-to-r from-pink-500 via-violet-500 to-blue-500 bg-clip-text text-transparent">
          👥 用户列表
        </h1>
        <p class="text-slate-500 dark:text-slate-400 mt-2">发现志同道合的创作者</p>
      </div>
      
      <!-- User Stats Card -->
      {username && (
        <a href={`${basePath}/profile`} class="block bg-white dark:bg-slate-800 rounded-2xl shadow-lg border border-slate-200 dark:border-slate-700 p-5 mb-8 hover:shadow-xl transition-shadow group">
          <div class="flex items-center justify-center gap-6">
            <div class="text-center">
              <div class="text-2xl font-bold text-pink-500">{currentUserFollowers}</div>
              <div class="text-xs text-slate-500">粉丝</div>
            </div>
            <div class="w-px h-10 bg-slate-200 dark:bg-slate-600"></div>
            <div class="text-center">
              <div class="text-2xl font-bold text-blue-500">{currentUserFollowing}</div>
              <div class="text-xs text-slate-500">关注</div>
            </div>
            <span class="text-slate-400 group-hover:translate-x-1 transition-transform">→</span>
          </div>
        </a>
      )}
      
      {!username && (
        <a href={`${basePath}/login`} class="block bg-gradient-to-r from-pink-500 to-violet-500 rounded-2xl p-6 mb-8 text-center text-white hover:shadow-xl transition-shadow">
          <p class="font-medium">登录后可以关注其他用户</p>
        </a>
      )}
      
      <!-- Users Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {usersWithCounts.map((user, index) => (
          <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-md border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-xl hover:border-pink-300 dark:hover:border-pink-700 transition-all group">
            <!-- Header gradient bar -->
            <div class="h-2 bg-gradient-to-r from-pink-400 via-violet-400 to-blue-400"></div>
            
            <div class="p-5">
              <div class="flex items-center gap-4">
                <!-- Avatar -->
                <a href={`${basePath}/user/${user.username}`} class="relative flex-shrink-0">
                  <img 
                    src={user.avatar ? `${basePath}${user.avatar}` : `${basePath}/avatars/default.svg`}
                    alt={user.username}
                    class="w-14 h-14 rounded-full object-cover ring-2 ring-pink-200 dark:ring-pink-800 group-hover:ring-pink-400 transition-all"
                  />
                  <!-- Rank badge -->
                  <div class="absolute -top-1 -right-1 w-6 h-6 bg-gradient-to-br from-blue-500 to-purple-500 rounded-full flex items-center justify-center text-white text-xs font-bold shadow-lg">
                    {index + 1}
                  </div>
                </a>
                
                <!-- Info -->
                <div class="flex-1 min-w-0">
                  <a href={`${basePath}/user/${user.username}`} class="block">
                    <h3 class="font-semibold text-slate-800 dark:text-slate-200 truncate group-hover:text-pink-500 transition-colors">
                      {user.username}
                    </h3>
                  </a>
                  <div class="flex items-center gap-2 mt-1">
                    {user.username === 'admin' && (
                      <span class="px-2 py-0.5 text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full">
                        管理员
                      </span>
                    )}
                    <span class="text-xs text-slate-400">
                      {new Date(user.created_at).toLocaleDateString('zh-CN')}
                    </span>
                  </div>
                </div>
              </div>
              
              <!-- Stats & Action -->
              <div class="flex items-center justify-between mt-4 pt-4 border-t border-slate-100 dark:border-slate-700">
                <div class="flex items-center gap-4 text-sm">
                  <span class="text-blue-500">
                    <span class="font-medium">{user.followingCount}</span>
                    <span class="text-slate-400 ml-1">关注</span>
                  </span>
                  <span class="text-pink-500">
                    <span class="font-medium">{user.followerCount}</span>
                    <span class="text-slate-400 ml-1">粉丝</span>
                  </span>
                </div>
                
                {username && username !== user.username && (
                  <button 
                    class="follow-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-all ${
                      user.isFollowing 
                        ? 'bg-slate-100 dark:bg-slate-700 text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-600' 
                        : 'bg-gradient-to-r from-pink-500 to-violet-500 text-white hover:shadow-lg'
                    }"
                    data-follower={username}
                    data-following={user.username}
                    data-is-following={user.isFollowing}
                  >
                    {user.isFollowing ? '已关注' : '+ 关注'}
                  </button>
                )}
                
                {username === user.username && (
                  <a 
                    href={`${basePath}/profile`}
                    class="px-4 py-1.5 rounded-lg text-sm font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 hover:bg-blue-200 transition-all"
                  >
                    编辑资料
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      
      {users.length === 0 && (
        <div class="text-center py-20 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700">
          <p class="text-5xl mb-4">👤</p>
          <p class="text-slate-500">暂无用户</p>
        </div>
      )}
    </div>
  </div>
  
  <script define:vars={{ basePath }}>
    document.querySelectorAll('.follow-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn;
        const follower = el.dataset.follower;
        const following = el.dataset.following;
        const isFollowing = el.dataset.isFollowing === 'true';
        const action = isFollowing ? 'unfollow' : 'follow';
        
        el.disabled = true;
        
        try {
          const res = await fetch(basePath + '/api/follow', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({ follower, following, action })
          });
          
          const data = await res.json();
          
          if (data.success) {
            el.dataset.isFollowing = data.following ? 'true' : 'false';
            if (data.following) {
              el.textContent = '已关注';
              el.className = 'follow-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-all bg-slate-100 dark:bg-slate-700 text-slate-500 hover:bg-slate-200 dark:hover:bg-slate-600';
            } else {
              el.textContent = '+ 关注';
              el.className = 'follow-btn px-4 py-1.5 rounded-lg text-sm font-medium transition-all bg-gradient-to-r from-pink-500 to-violet-500 text-white hover:shadow-lg';
            }
          }
        } catch (err) {
          console.error(err);
        }
        
        el.disabled = false;
      });
    });
  </script>
</Layout>
