---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getProductBySlug, getAllProducts } from '../../lib/auth';

const { slug } = Astro.params;
const product = slug ? getProductBySlug(slug) : null;

if (!product) {
  return Astro.redirect('/xuanchen_content/products');
}

const allProducts = getAllProducts().filter(p => p.slug !== product.slug);
const relatedProducts = allProducts.slice(0, 4);
const basePath = '/xuanchen_content';
---

<Layout 
  title={product.name}
  description={product.description}
  image={product.image}
>
  <div class="min-h-screen bg-[#fafbfc] dark:bg-[#0f1117]">
    <!-- Header -->
    <div class="bg-white dark:bg-[#1a1d27] border-b border-slate-200/80 dark:border-slate-800">
      <div class="max-w-5xl mx-auto px-6 py-4">
        <a href={`${basePath}/products`} class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
          </svg>
          <span>精选产品</span>
        </a>
      </div>
    </div>

    <!-- Main -->
    <main class="max-w-5xl mx-auto px-6 py-12 md:py-20">
      <div class="max-w-2xl mx-auto text-center">
        <!-- Icon -->
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-[#3b82f6] to-[#8b5cf6] mb-8 shadow-lg shadow-blue-500/20">
          <span class="text-3xl">{product.icon}</span>
        </div>

        <!-- Title -->
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-6 tracking-tight">
          {product.name}
        </h1>

        <!-- Description -->
        <p class="text-lg text-slate-500 dark:text-slate-400 leading-relaxed mb-10">
          {product.description}
        </p>

        <!-- CTA -->
        <a 
          href={product.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 px-7 py-3.5 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-medium rounded-full hover:bg-slate-800 dark:hover:bg-slate-100 transition-colors"
        >
          <span>访问官网</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

      <!-- Image -->
      {product.image && (
        <div class="mt-16 rounded-2xl overflow-hidden shadow-xl shadow-slate-200/50 dark:shadow-black/30">
          <img 
            src={product.image} 
            alt={product.name}
            class="w-full object-cover"
          />
        </div>
      )}
    </main>

    <!-- Related -->
    {relatedProducts.length > 0 && (
      <div class="max-w-5xl mx-auto px-6 pb-20">
        <h2 class="text-sm font-medium text-slate-400 uppercase tracking-wider mb-6">更多产品</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {relatedProducts.map(p => (
            <a 
              href={`${basePath}/products/${p.slug}`}
              class="group p-4 bg-white dark:bg-[#1a1d27] rounded-xl border border-slate-200/80 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-700 hover:shadow-md transition-all"
            >
              <div class="flex items-center gap-3 mb-2">
                <span class="text-2xl">{p.icon}</span>
                <span class="font-medium text-slate-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate">
                  {p.name}
                </span>
              </div>
              <p class="text-xs text-slate-500 dark:text-slate-500 line-clamp-2">
                {p.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>
