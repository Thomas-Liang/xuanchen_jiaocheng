---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { getProductById } from '../../../lib/auth';

const { id } = Astro.params;
const productId = id ? parseInt(id) : null;
const product = productId ? getProductById(productId) : null;
const basePath = '/xuanchen_content';

if (!product) {
  return Astro.redirect(`${basePath}/products`);
}

const emojis = ['🤖', '🚀', '💻', '☁️', '🔒', '📊', '🛠️', '⚡', '🔥', '💫', '🌟', '✨', '🎨', '📱', '🖥️', '🔧', '📦', '💡', '🔮', '🎁', '📚', '🧩', '⚙️', '🎯', '🔗'];
---

<Layout title="编辑产品 - 泫晨云栖">
  <div class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-blue-50 dark:from-slate-900 dark:via-slate-800 dark:to-slate-900">
    <!-- Header -->
    <header class="sticky top-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border-b border-slate-200/50 dark:border-slate-700/50">
      <div class="max-w-4xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <a href={`${basePath}/admin`} class="group flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
              <span class="p-2 rounded-xl bg-slate-100 dark:bg-slate-800 group-hover:bg-blue-100 dark:group-hover:bg-blue-900/30 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
              </span>
              <span class="font-medium">返回</span>
            </a>
            <div class="h-6 w-px bg-slate-200 dark:bg-slate-700"></div>
            <h1 class="text-xl font-bold bg-gradient-to-r from-slate-800 to-slate-600 dark:from-white dark:to-slate-300 bg-clip-text text-transparent">
              编辑产品
            </h1>
          </div>
        </div>
      </div>
    </header>
    
    <main class="max-w-4xl mx-auto px-6 py-8">
      <form id="productForm" class="space-y-8">
        <input type="hidden" name="id" value={product.id} />
        
        <!-- Basic Info -->
        <div class="bg-white/60 dark:bg-slate-800/60 backdrop-blur-sm rounded-3xl border border-slate-200/50 dark:border-slate-700/50 p-8 shadow-xl shadow-green-500/5">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2 rounded-xl bg-gradient-to-br from-green-500 to-emerald-500 text-white">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-slate-800 dark:text-white">产品信息</h2>
          </div>
          
          <div class="space-y-5">
            <div>
              <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">产品名称</label>
              <input 
                type="text" 
                name="name" 
                required 
                value={product.name} 
                class="w-full px-5 py-4 rounded-2xl border border-slate-200 dark:border-slate-600 bg-white/80 dark:bg-slate-700/50 text-slate-800 dark:text-white text-lg font-medium placeholder-slate-400 focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition-all shadow-sm hover:shadow-md focus:shadow-green-500/20"
                placeholder="输入产品名称"
              />
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">图标</label>
              <div class="flex gap-3">
                <div class="relative flex-1">
                  <input 
                    type="text" 
                    name="icon" 
                    id="iconInput"
                    value={product.icon} 
                    class="w-full px-5 py-4 rounded-2xl border border-slate-200 dark:border-slate-600 bg-white/80 dark:bg-slate-700/50 text-slate-800 dark:text-white text-lg font-medium placeholder-slate-400 focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition-all shadow-sm hover:shadow-md focus:shadow-green-500/20 pr-12"
                    placeholder="选择图标"
                  />
                  <span id="iconPreview" class="absolute right-5 top-1/2 -translate-y-1/2 text-2xl">{product.icon}</span>
                </div>
                <button type="button" id="toggleEmoji" class="px-5 py-4 rounded-2xl bg-gradient-to-r from-green-500 to-emerald-500 text-white font-medium hover:shadow-lg transition-all">
                  选择
                </button>
              </div>
              <div id="emojiPicker" class="hidden mt-3 p-4 bg-white dark:bg-slate-700 rounded-2xl border border-slate-200 dark:border-slate-600 shadow-lg">
                <div class="grid grid-cols-9 gap-2">
                  {emojis.map(emoji => (
                    <button type="button" class="emoji-btn w-10 h-10 flex items-center justify-center text-xl hover:bg-slate-100 dark:hover:bg-slate-600 rounded-lg transition-colors">
                      {emoji}
                    </button>
                  ))}
                </div>
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">官网链接</label>
              <input 
                type="url" 
                name="url" 
                required 
                value={product.url} 
                class="w-full px-5 py-4 rounded-2xl border border-slate-200 dark:border-slate-600 bg-white/80 dark:bg-slate-700/50 text-slate-800 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition-all shadow-sm hover:shadow-md focus:shadow-green-500/20"
                placeholder="https://example.com"
              />
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">描述</label>
              <textarea 
                name="description" 
                required 
                rows="4"
                class="w-full px-5 py-4 rounded-2xl border border-slate-200 dark:border-slate-600 bg-white/80 dark:bg-slate-700/50 text-slate-800 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition-all shadow-sm hover:shadow-md focus:shadow-green-500/20 resize-none"
                placeholder="简要描述产品..."
              >{product.description}</textarea>
            </div>
          </div>
        </div>

        <!-- Image -->
        <div class="bg-white/60 dark:bg-slate-800/60 backdrop-blur-sm rounded-3xl border border-slate-200/50 dark:border-slate-700/50 p-8 shadow-xl shadow-purple-500/5">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 text-white">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="text-lg font-bold text-slate-800 dark:text-white">产品图片</h2>
          </div>

          <div class="space-y-4">
            <input type="hidden" id="productId" value={product.id} />
            
            <!-- Upload Section -->
            <div>
              <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2">上传图片</label>
              <div class="flex items-center gap-3">
                <input 
                  type="file" 
                  id="imageFileInput"
                  accept="image/jpeg,image/png,image/gif,image/webp"
                  class="hidden"
                />
                <button 
                  type="button"
                  id="uploadImageBtn"
                  class="px-5 py-3 bg-gradient-to-r from-purple-500 to-pink-500 text-white font-medium rounded-xl hover:shadow-lg transition-all flex items-center gap-2"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                  </svg>
                  选择图片
                </button>
                <span id="imageFileName" class="text-sm text-slate-500 dark:text-slate-400"></span>
              </div>
              <p class="mt-2 text-xs text-slate-400">支持 JPG、PNG、GIF、WebP 格式，最大 5MB</p>
            </div>

            <!-- URL Section -->
            <div class="relative">
              <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-slate-200 dark:border-slate-600"></div>
              </div>
              <div class="relative flex justify-center text-sm">
                <span class="px-2 bg-white/60 dark:bg-slate-800/60 text-slate-400">或输入图片链接</span>
              </div>
            </div>
            
            <div class="relative">
              <input 
                type="url" 
                name="image" 
                id="imageInput"
                value={product.image || ''} 
                class="w-full px-5 py-4 rounded-2xl border border-slate-200 dark:border-slate-600 bg-white/80 dark:bg-slate-700/50 text-slate-800 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none transition-all shadow-sm hover:shadow-md"
                placeholder="https://example.com/image.png"
              />
              <button 
                type="button"
                id="previewFromUrlBtn"
                class="absolute right-3 top-1/2 -translate-y-1/2 px-3 py-1 text-sm bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded-lg hover:bg-purple-200 dark:hover:bg-purple-900/50 transition-colors"
              >
                预览
              </button>
            </div>
            
            <!-- Preview -->
            <div id="imagePreview" class={`mt-4 ${!product.image ? 'hidden' : ''}`}>
              <div class="relative rounded-2xl overflow-hidden shadow-lg group">
                <img id="previewImg" src={product.image || ''} alt="Preview" class="w-full h-48 object-cover" />
                <button 
                  type="button"
                  id="removeImageBtn"
                  class="absolute top-2 right-2 p-2 bg-red-500/80 hover:bg-red-500 text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <p class="mt-2 text-sm text-green-600 dark:text-green-400">图片已加载</p>
            </div>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex flex-col-reverse sm:flex-row gap-4 justify-end pt-4">
          <a href={`${basePath}/products`} class="px-8 py-4 text-center border-2 border-slate-200 dark:border-slate-600 text-slate-700 dark:text-slate-300 rounded-2xl hover:bg-slate-100 dark:hover:bg-slate-700 transition-all font-semibold">
            取消编辑
          </a>
          <button 
            type="submit"
            class="px-10 py-4 bg-gradient-to-r from-green-500 to-emerald-500 hover:from-green-600 hover:to-emerald-600 text-white font-bold rounded-2xl shadow-xl shadow-green-500/30 hover:shadow-2xl hover:shadow-green-500/40 transition-all flex items-center justify-center gap-3 text-lg"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            保存产品
          </button>
        </div>
      </form>
    </main>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 px-6 py-3 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-full shadow-lg transform translate-y-20 opacity-0 transition-all duration-300 z-50">
    保存成功
  </div>

  <script>
    const iconInput = document.getElementById('iconInput') as HTMLInputElement;
    const iconPreview = document.getElementById('iconPreview') as HTMLElement;
    const toggleBtn = document.getElementById('toggleEmoji') as HTMLButtonElement;
    const picker = document.getElementById('emojiPicker') as HTMLElement;
    const imageInput = document.getElementById('imageInput') as HTMLInputElement;
    const imagePreview = document.getElementById('imagePreview') as HTMLElement;
    const previewImg = document.getElementById('previewImg') as HTMLImageElement;
    const imageFileInput = document.getElementById('imageFileInput') as HTMLInputElement;
    const uploadImageBtn = document.getElementById('uploadImageBtn') as HTMLButtonElement;
    const imageFileName = document.getElementById('imageFileName') as HTMLElement;
    const previewFromUrlBtn = document.getElementById('previewFromUrlBtn') as HTMLButtonElement;
    const removeImageBtn = document.getElementById('removeImageBtn') as HTMLButtonElement;
    const productId = document.getElementById('productId') as HTMLInputElement;

    toggleBtn?.addEventListener('click', () => {
      picker.classList.toggle('hidden');
    });

    document.querySelectorAll('.emoji-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const emoji = btn.textContent || '';
        iconInput.value = emoji;
        iconPreview.textContent = emoji;
        picker.classList.add('hidden');
      });
    });

    document.addEventListener('click', (e) => {
      if (!toggleBtn?.contains(e.target as Node) && !picker?.contains(e.target as Node)) {
        picker?.classList.add('hidden');
      }
    });

    // Image upload functionality
    uploadImageBtn?.addEventListener('click', () => {
      imageFileInput?.click();
    });

    imageFileInput?.addEventListener('change', async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      imageFileName.textContent = file.name;

      const formData = new FormData();
      formData.append('image', file);
      formData.append('productId', productId.value);

      try {
        uploadImageBtn.disabled = true;
        uploadImageBtn.innerHTML = '<span class="animate-spin inline-block w-5 h-5 border-2 border-white border-t-transparent rounded-full"></span> 上传中...';

        const res = await fetch('/xuanchen_content/api/product-image/upload', {
          method: 'POST',
          body: formData
        });

        const data = await res.json();

        if (data.success) {
          imageInput.value = data.image;
          previewImg.src = data.image;
          imagePreview.classList.remove('hidden');
          imageFileName.textContent = '';
        } else {
          alert(data.error || '上传失败');
        }
      } catch (err) {
        alert('上传失败');
        console.error(err);
      } finally {
        uploadImageBtn.disabled = false;
        uploadImageBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg> 选择图片';
      }
    });

    previewFromUrlBtn?.addEventListener('click', () => {
      const url = imageInput.value;
      if (url) {
        previewImg.src = url;
        imagePreview.classList.remove('hidden');
      }
    });

    imageInput?.addEventListener('input', () => {
      const url = imageInput.value;
      if (url) {
        previewImg.src = url;
        imagePreview.classList.remove('hidden');
      } else {
        imagePreview.classList.add('hidden');
      }
    });

    removeImageBtn?.addEventListener('click', () => {
      imageInput.value = '';
      imagePreview.classList.add('hidden');
    });

    const form = document.getElementById('productForm') as HTMLFormElement;
    const toast = document.getElementById('toast') as HTMLElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = {
        id: parseInt(formData.get('id') as string),
        name: formData.get('name'),
        icon: formData.get('icon'),
        url: formData.get('url'),
        description: formData.get('description'),
        image: formData.get('image') || null,
        action: 'update'
      };

      try {
        const res = await fetch('/xuanchen_content/api/products', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const result = await res.json();
        if (result.success) {
          toast.textContent = '保存成功';
          toast.classList.remove('translate-y-20', 'opacity-0');
          setTimeout(() => {
            toast.classList.add('translate-y-20', 'opacity-0');
            window.location.href = '/xuanchen_content/admin?tab=products';
          }, 1500);
        } else {
          toast.textContent = result.error || '保存失败';
          toast.classList.remove('translate-y-20', 'opacity-0');
          setTimeout(() => toast.classList.add('translate-y-20', 'opacity-0'), 2000);
        }
      } catch (err) {
        toast.textContent = '请求失败';
        toast.classList.remove('translate-y-20', 'opacity-0');
        setTimeout(() => toast.classList.add('translate-y-20', 'opacity-0'), 2000);
      }
    });
  </script>
</Layout>
