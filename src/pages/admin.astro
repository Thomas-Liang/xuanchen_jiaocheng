  <script>
    const basePath = '/xuanchen_content';
    
    function showToast(message, type) {
      type = type || 'success';
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toast-message');
      if (!toast || !toastMsg) return;
      
      toastMsg.textContent = message;
      toast.className = `fixed top-4 right-4 px-6 py-3 rounded-xl shadow-lg transform transition-all duration-300 z-50 ${
        type === 'success' 
          ? 'bg-green-500 text-white' 
          : 'bg-red-500 text-white'
      }`;
      
      setTimeout(() => {
        toast.classList.remove('translate-x-full', 'opacity-0');
      }, 10);
      
      setTimeout(() => {
        toast.classList.add('translate-x-full', 'opacity-0');
      }, 2500);
    }

    // Tab switching
    function switchTab(tabName) {
      console.log('Switching to: ' + tabName);
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('text-blue-600', 'border-blue-500', 'bg-blue-50/50', 'dark:bg-blue-900/20');
        b.classList.add('text-slate-500', 'border-transparent');
      });
      const activeBtn = document.querySelector(`[data-tab="${tabName}"]`);
      activeBtn?.classList.remove('text-slate-500', 'border-transparent');
      activeBtn?.classList.add('text-blue-600', 'border-blue-500', 'bg-blue-50/50', 'dark:bg-blue-900/20');
      
      document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
      document.getElementById('tab-' + tabName)?.classList.remove('hidden');
      
      if (tabName === 'stats') {
        loadStats();
      }
      if (tabName === 'smtp') {
        loadSmtpConfig();
      }
    }

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabName = btn.dataset.tab;
        if (tabName) switchTab(tabName);
      });
    });

    // Check URL params for initial tab on page load
    const urlParams = new URLSearchParams(window.location.search);
    const initialTab = urlParams.get('tab');
    if (initialTab) {
      switchTab(initialTab);
    } else {
      switchTab('tutorials');
    }

    // Tutorial delete
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('确定要删除这个教程吗？')) return;
        
        const slug = btn.dataset.slug;
        const res = await fetch(basePath + '/api/tutorials/delete?slug=' + slug, {
          method: 'DELETE'
        });
        
        if (res.ok) {
          showToast('删除成功！');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showToast('删除失败', 'error');
        }
      });
    });

    // Reset views
    document.querySelectorAll('.reset-views-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('确定要重置这篇教程的阅读量吗？')) return;
        
        const slug = btn.dataset.slug;
        const res = await fetch(basePath + '/api/pageviews', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, action: 'reset' })
        });
        
        const data = await res.json();
        if (data.success) {
          showToast('阅读量已重置！');
          const viewCountEl = document.querySelector(`.view-count[data-slug="${slug}"]`);
          if (viewCountEl) {
            viewCountEl.textContent = '👁 0';
          }
        } else {
          showToast('重置失败', 'error');
        }
      });
    });

    // Pin tutorial
    document.querySelectorAll('.pin-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn;
        const slug = el.dataset.slug;
        const isPinned = el.dataset.pinned === 'true';
        const action = isPinned ? 'unpin' : 'pin';
        
        const formData = new FormData();
        formData.append('slug', slug || '');
        formData.append('action', action);
        
        const res = await fetch(basePath + '/api/tutorials/pin', {
          method: 'POST',
          body: formData
        });
        
        const data = await res.json();
        if (data.success) {
          showToast(isPinned ? '已取消置顶' : '已置顶');
          setTimeout(() => window.location.reload(), 500);
        } else {
          showToast('操作失败', 'error');
        }
      });
    });

    // Project Modal
    const projectModal = document.getElementById('project-modal');
    const projectForm = document.getElementById('project-form');
    
    document.getElementById('add-project-btn')?.addEventListener('click', () => {
      document.getElementById('project-modal-title').textContent = '添加项目';
      document.getElementById('project-id').value = '';
      document.getElementById('project-icon').value = '📦';
      document.getElementById('project-name').value = '';
      document.getElementById('project-description').value = '';
      document.getElementById('project-url').value = '';
      projectModal?.classList.remove('hidden');
      projectModal?.classList.add('flex');
    });
    
    document.getElementById('cancel-project')?.addEventListener('click', () => {
      projectModal?.classList.add('hidden');
      projectModal?.classList.remove('flex');
    });
    
    projectModal?.addEventListener('click', (e) => {
      if (e.target === projectModal) {
        projectModal.classList.add('hidden');
        projectModal.classList.remove('flex');
      }
    });
    
    projectForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(projectForm);
      const id = formData.get('id');
      const data = {
        name: formData.get('name'),
        description: formData.get('description'),
        url: formData.get('url'),
        icon: formData.get('icon'),
        action: id ? 'update' : 'create',
        id: id || null
      };
      
      const res = await fetch(basePath + '/api/projects', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      const result = await res.json();
      if (result.success) {
        showToast(id ? '项目已更新！' : '项目已添加！');
        projectModal?.classList.add('hidden');
        projectModal?.classList.remove('flex');
        setTimeout(() => window.location.reload(), 1000);
      } else {
        showToast('操作失败', 'error');
      }
    });
    
    document.querySelectorAll('.delete-project-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn;
        if (!confirm(`确定要删除项目「${el.dataset.name}」吗？`)) return;
        
        const res = await fetch(basePath + '/api/projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'delete', id: el.dataset.id })
        });
        
        const result = await res.json();
        if (result.success) {
          showToast('项目已删除！');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showToast('删除失败', 'error');
        }
      });
    });

    // Workflow Modal
    const workflowModal = document.getElementById('workflow-modal');
    const workflowForm = document.getElementById('workflow-form');
    
    document.getElementById('add-workflow-btn')?.addEventListener('click', () => {
      document.getElementById('workflow-modal-title').textContent = '添加工作流';
      document.getElementById('workflow-id').value = '';
      document.getElementById('workflow-icon').value = '⚡';
      document.getElementById('workflow-name').value = '';
      document.getElementById('workflow-description').value = '';
      document.getElementById('workflow-tags').value = '';
      document.getElementById('workflow-url').value = '';
      workflowModal?.classList.remove('hidden');
      workflowModal?.classList.add('flex');
    });
    
    document.getElementById('cancel-workflow')?.addEventListener('click', () => {
      workflowModal?.classList.add('hidden');
      workflowModal?.classList.remove('flex');
    });
    
    workflowModal?.addEventListener('click', (e) => {
      if (e.target === workflowModal) {
        workflowModal.classList.add('hidden');
        workflowModal.classList.remove('flex');
      }
    });
    
    workflowForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(workflowForm);
      const id = formData.get('id');
      const data = {
        name: formData.get('name'),
        description: formData.get('description'),
        icon: formData.get('icon'),
        tags: formData.get('tags'),
        url: formData.get('url'),
        action: id ? 'update' : 'create',
        id: id || null
      };
      
      const res = await fetch(basePath + '/api/workflows', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      const result = await res.json();
      if (result.success) {
        showToast(id ? '工作流已更新！' : '工作流已添加！');
        workflowModal?.classList.add('hidden');
        workflowModal?.classList.remove('flex');
        setTimeout(() => window.location.reload(), 1000);
      } else {
        showToast('操作失败', 'error');
      }
    });
    
    document.querySelectorAll('.delete-workflow-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn;
        if (!confirm(`确定要删除工作流「${el.dataset.name}」吗？`)) return;
        
        const res = await fetch(basePath + '/api/workflows', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'delete', id: el.dataset.id })
        });
        
        const result = await res.json();
        if (result.success) {
          showToast('工作流已删除！');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showToast('删除失败', 'error');
        }
      });
    });

    // Product Modal
    const productModal = document.getElementById('product-modal');
    const productForm = document.getElementById('product-form');
    
    document.getElementById('add-product-btn')?.addEventListener('click', () => {
      document.getElementById('product-modal-title').textContent = '添加产品';
      document.getElementById('product-id').value = '';
      document.getElementById('product-icon').value = '📦';
      document.getElementById('product-name').value = '';
      document.getElementById('product-description').value = '';
      document.getElementById('product-url').value = '';
      document.getElementById('product-image').value = '';
      productModal?.classList.remove('hidden');
      productModal?.classList.add('flex');
    });
    
    document.getElementById('cancel-product')?.addEventListener('click', () => {
      productModal?.classList.add('hidden');
      productModal?.classList.remove('flex');
    });
    
    productModal?.addEventListener('click', (e) => {
      if (e.target === productModal) {
        productModal.classList.add('hidden');
        productModal.classList.remove('flex');
      }
    });
    
    productForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(productForm);
      const id = formData.get('id');
      const data = {
        name: formData.get('name'),
        description: formData.get('description'),
        url: formData.get('url'),
        icon: formData.get('icon'),
        image: formData.get('image'),
        action: id ? 'update' : 'create',
        id: id || null
      };
      
      const res = await fetch(basePath + '/api/products', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      const result = await res.json();
      if (result.success) {
        showToast(id ? '产品已更新！' : '产品已添加！');
        productModal?.classList.add('hidden');
        productModal?.classList.remove('flex');
        setTimeout(() => window.location.reload(), 1000);
      } else {
        showToast('操作失败', 'error');
      }
    });
    
    document.querySelectorAll('.delete-product-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn;
        if (!confirm(`确定要删除产品「${el.dataset.name}」吗？`)) return;
        
        const res = await fetch(basePath + '/api/products', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'delete', id: el.dataset.id })
        });
        
        const result = await res.json();
        if (result.success) {
          showToast('产品已删除！');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showToast('删除失败', 'error');
        }
      });
    });

    // Stats tab - load data when tab is shown
    let statsLoaded = false;
    
    function loadStats() {
      if (statsLoaded) return;
      statsLoaded = true;
      console.log('Loading stats...');
      
      fetch(basePath + '/api/stats')
        .then(res => res.json())
        .then(data => {
          if (data.totalViews !== undefined) {
            document.getElementById('stat-total').textContent = data.totalViews.toLocaleString();
            document.getElementById('stat-pages').textContent = data.pageCount.toLocaleString();
            document.getElementById('stat-avg').textContent = data.pageCount > 0 ? Math.round(data.totalViews / data.pageCount).toLocaleString() : '0';
            
            const listEl = document.getElementById('stats-list');
            if (listEl && data.topPages && data.topPages.length > 0) {
              const maxViews = Math.max(...data.topPages.map(function(p) { return p.count; }));
              listEl.innerHTML = data.topPages.map(function(p, i) {
                const percentage = maxViews > 0 ? (p.count / maxViews * 100) : 0;
                return '<div class="p-4 flex items-center gap-4">' +
                  '<div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center text-white text-sm font-bold">' + (i + 1) + '</div>' +
                  '<div class="flex-1 min-w-0">' +
                    '<div class="font-medium text-slate-800 dark:text-slate-200 truncate">' + p.slug + '</div>' +
                    '<div class="mt-2 h-2 bg-slate-100 dark:bg-slate-700 rounded-full overflow-hidden">' +
                      '<div class="h-full bg-gradient-to-r from-blue-500 to-cyan-500 rounded-full transition-all duration-500" style="width: ' + percentage + '%"></div>' +
                    '</div>' +
                  '</div>' +
                  '<div class="text-right flex-shrink-0">' +
                    '<div class="font-bold text-slate-800 dark:text-slate-200">' + p.count.toLocaleString() + '</div>' +
                    '<div class="text-xs text-slate-500">次访问</div>' +
                  '</div>' +
                '</div>';
              }).join('');
            } else if (listEl) {
              listEl.innerHTML = '<div class="p-6 text-center text-slate-500">暂无数据</div>';
            }
            statsLoaded = true;
          }
        })
        .catch(err => {
          console.error('Failed to load stats:', err);
          const listEl = document.getElementById('stats-list');
          if (listEl) listEl.innerHTML = '<div class="p-6 text-center text-red-500">加载失败</div>';
        });
    }
    
    // SMTP Settings
    let smtpLoaded = false;
    
    function loadSmtpConfig() {
      if (smtpLoaded) return;
      smtpLoaded = true;
      
      fetch(basePath + '/api/config')
        .then(res => res.json())
        .then(data => {
          const smtp = data.smtp || {};
          const site = data.site || {};
          
          document.getElementById('smtp-enabled').checked = smtp.enabled || false;
          document.getElementById('smtp-host').value = smtp.host || '';
          document.getElementById('smtp-port').value = smtp.port || '587';
          document.getElementById('smtp-user').value = smtp.user || '';
          document.getElementById('smtp-pass').value = smtp.pass ? '********' : '';
          document.getElementById('smtp-from').value = smtp.from || '';
          document.getElementById('site-url').value = site.url || '';
          document.getElementById('site-name').value = site.name || '';
          
          smtpLoaded = true;
        })
        .catch(err => console.error('Failed to load config:', err));
    }
    
    document.getElementById('save-smtp-btn')?.addEventListener('click', () => {
      const btn = document.getElementById('save-smtp-btn');
      const smtpEnabled = document.getElementById('smtp-enabled')?.checked;
      const smtpHost = document.getElementById('smtp-host')?.value;
      const smtpPort = document.getElementById('smtp-port')?.value;
      const smtpUser = document.getElementById('smtp-user')?.value;
      const smtpPass = document.getElementById('smtp-pass')?.value;
      const smtpFrom = document.getElementById('smtp-from')?.value;
      const siteUrl = document.getElementById('site-url')?.value;
      const siteName = document.getElementById('site-name')?.value;
      
      if (!smtpHost || !smtpUser) {
        showToast('请填写必填项', 'error');
        return;
      }
      
      btn.disabled = true;
      btn.textContent = '保存中...';
      
      const config = {
        smtp: { enabled: smtpEnabled, host: smtpHost, port: smtpPort, user: smtpUser, pass: smtpPass === '********' ? undefined : smtpPass, from: smtpFrom },
        site: { url: siteUrl, name: siteName }
      };
      
      fetch(basePath + '/api/config', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(config)
      })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            showToast('设置已保存！');
            if (smtpPass !== '********') {
              document.getElementById('smtp-pass').value = '********';
            }
          } else {
            showToast(data.error || '保存失败', 'error');
          }
        })
        .catch(err => {
          console.error(err);
          showToast('保存失败', 'error');
        })
        .finally(() => {
          btn.disabled = false;
          btn.textContent = '保存设置';
        });
    });
    
    document.getElementById('test-smtp-btn')?.addEventListener('click', () => {
      const email = prompt('请输入测试收件邮箱：');
      if (!email) return;
      
      const btn = document.getElementById('test-smtp-btn');
      btn.disabled = true;
      btn.textContent = '发送中...';
      
      const testHtml = `
        <html>
        <body style="font-family: sans-serif; padding: 20px;">
          <h2>🎉 测试邮件</h2>
          <p>这是一封来自泫晨云栖的测试邮件。</p>
          <p>如果收到这封邮件，说明 SMTP 配置正确！</p>
          <p>发送时间：${new Date().toLocaleString('zh-CN')}</p>
        </body>
        </html>
      `;
      
      fetch(basePath + '/api/config/send-test', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to: email, subject: '泫晨云栖 - 邮件配置测试', html: testHtml })
      })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            showToast('测试邮件已发送！');
          } else {
            showToast(data.error || '发送失败', 'error');
          }
        })
        .catch(err => {
          console.error(err);
          showToast('发送失败', 'error');
        })
        .finally(() => {
          btn.disabled = false;
          btn.textContent = '发送测试邮件';
        });
    });
  </script>
</Layout>
