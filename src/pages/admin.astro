---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { getAllTutorials, getPublishedTutorials } from '../lib/tutorial';
import { getAllPageviews, getAllProjects, getAllWorkflows, getAllProducts, getPinnedTutorials, isTutorialPinned } from '../lib/auth';

const username = Astro.cookies.get('username')?.value;
const basePath = '/xuanchen_content';

if (!username) {
  return Astro.redirect(`${basePath}/login`);
}

const pinnedSlugs = getPinnedTutorials();
let tutorials = getAllTutorials();
tutorials = tutorials
  .map(t => ({ ...t, isPinned: pinnedSlugs.includes(t.slug) }))
  .sort((a, b) => {
    if (a.isPinned && !b.isPinned) return -1;
    if (!a.isPinned && b.isPinned) return 1;
    const dateA = a.lastModified || a.publishDate;
    const dateB = b.lastModified || b.publishDate;
    return new Date(dateB).getTime() - new Date(dateA).getTime();
  });

const pageviews = getAllPageviews();
const pageviewMap = new Map(pageviews.map(p => [p.slug, p.count]));

const projects = getAllProjects();
const workflows = getAllWorkflows();
const products = getAllProducts();
---

<Layout title="管理后台 - 泫晨云栖">
  <!-- Toast Notification -->
  <div id="toast" class="fixed top-4 right-4 px-6 py-3 rounded-xl shadow-lg transform translate-x-full opacity-0 transition-all duration-300 z-50">
    <span id="toast-message"></span>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold text-slate-800 dark:text-slate-200">管理后台</h1>
    </div>
    
    <!-- Tab Navigation -->
    <div class="flex gap-2 mb-6 border-b border-slate-200 dark:border-slate-700">
      <button data-tab="tutorials" class="tab-btn px-6 py-3 text-sm font-medium text-blue-600 border-b-2 border-blue-500 bg-blue-50/50 dark:bg-blue-900/20 rounded-t-lg transition-colors">
        📚 教程管理
      </button>
      <button data-tab="projects" class="tab-btn px-6 py-3 text-sm font-medium text-slate-500 border-b-2 border-transparent hover:text-slate-700 dark:hover:text-slate-300 rounded-t-lg transition-colors">
        📦 开源项目
      </button>
      <button data-tab="workflows" class="tab-btn px-6 py-3 text-sm font-medium text-slate-500 border-b-2 border-transparent hover:text-slate-700 dark:hover:text-slate-300 rounded-t-lg transition-colors">
        ⚡ 工作流
      </button>
      <button data-tab="products" class="tab-btn px-6 py-3 text-sm font-medium text-slate-500 border-b-2 border-transparent hover:text-slate-700 dark:hover:text-slate-300 rounded-t-lg transition-colors">
        🎁 精选产品
      </button>
      <button data-tab="stats" class="tab-btn px-6 py-3 text-sm font-medium text-slate-500 border-b-2 border-transparent hover:text-slate-700 dark:hover:text-slate-300 rounded-t-lg transition-colors">
        📊 站点统计
      </button>
      <button data-tab="smtp" class="tab-btn px-6 py-3 text-sm font-medium text-slate-500 border-b-2 border-transparent hover:text-slate-700 dark:hover:text-slate-300 rounded-t-lg transition-colors">
        📧 邮件设置
      </button>
    </div>
    
    <!-- Tab Content Container -->
    <div class="tab-contents">
      <!-- Tutorials Tab -->
      <div id="tab-tutorials" class="tab-content hidden">
      <div class="flex justify-end mb-4">
        <a href={`${basePath}/tutorials/new`} class="px-4 py-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white rounded-lg hover:shadow-lg hover:shadow-blue-500/25 transition-all">
          + 新建教程
        </a>
      </div>
      
      {tutorials.length > 0 ? (
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
          <div class="divide-y divide-slate-200 dark:divide-slate-700">
            {tutorials.map(tutorial => (
              <div class="p-4 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                {tutorial.coverImage && (
                  <div class="flex-shrink-0 w-full sm:w-24 h-32 sm:h-16 overflow-hidden rounded-lg">
                    <img src={tutorial.coverImage} alt="" class="w-full h-full object-cover" />
                  </div>
                )}
                <div class="flex-1 min-w-0 w-full">
                  <h3 class="text-base sm:text-lg font-semibold text-slate-800 dark:text-slate-200 truncate">
                    {tutorial.title}
                  </h3>
                  <p class="text-sm text-slate-500 truncate hidden sm:block">{tutorial.description}</p>
                  <div class="flex flex-wrap items-center gap-2 sm:gap-4 mt-2 text-xs text-slate-400">
                    <span>{tutorial.author}</span>
                    <span class="hidden sm:inline">•</span>
                    <span>{tutorial.lastModified || tutorial.publishDate}</span>
                    <span class="hidden sm:inline">•</span>
                    <span>{tutorial.readingTime} min</span>
                    <span class="hidden sm:inline">•</span>
                    <span class="view-count text-blue-600 dark:text-blue-400 font-medium" data-slug={tutorial.slug}>👁 {pageviewMap.get(tutorial.slug) || 0}</span>
                  </div>
                </div>
                <div class="flex items-center gap-2 sm:gap-3 w-full sm:w-auto justify-end">
                  <button 
                    class="pin-btn px-3 py-2 text-sm transition-colors rounded-lg"
                    data-slug={tutorial.slug}
                    data-pinned={tutorial.isPinned ? 'true' : 'false'}
                    title={tutorial.isPinned ? '取消置顶' : '置顶'}
                  >
                    {tutorial.isPinned ? '📌' : '📍'}
                  </button>
                  <button 
                    class="reset-views-btn px-3 py-2 text-sm text-green-600 hover:bg-green-50 dark:hover:bg-green-900/30 rounded-lg transition-colors"
                    data-slug={tutorial.slug}
                    title="重置阅读量"
                  >
                    🔄
                  </button>
                  <a href={`${basePath}/tutorials/${tutorial.slug}/edit`} class="px-3 py-2 text-sm text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-lg transition-colors">
                    编辑
                  </a>
                  <button 
                    class="delete-btn px-3 py-2 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-lg transition-colors"
                    data-slug={tutorial.slug}
                  >
                    删除
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="text-center py-12 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700">
          <p class="text-slate-500 mb-4">暂无教程</p>
          <a href={`${basePath}/tutorials/new`} class="text-blue-600 hover:underline">
            创建第一个教程
          </a>
        </div>
      )}
    </div>

    <!-- Projects Tab -->
    <div id="tab-projects" class="tab-content hidden">
      <div class="flex justify-end mb-4">
        <button id="add-project-btn" class="px-4 py-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white rounded-lg hover:shadow-lg hover:shadow-blue-500/25 transition-all">
          + 添加项目
        </button>
      </div>
      
      {projects.length > 0 ? (
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
          <div class="divide-y divide-slate-200 dark:divide-slate-700">
            {projects.map(project => (
              <div class="p-4 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
              <div class="flex items-center gap-4 flex-1 min-w-0 overflow-hidden">
                <span class="text-3xl flex-shrink-0">{project.icon || '📦'}</span>
                  <div class="min-w-0">
                    <h3 class="text-base sm:text-lg font-semibold text-slate-800 dark:text-slate-200 truncate">
                      {project.name}
                    </h3>
                    <p class="text-sm text-slate-500 truncate hidden sm:block">{project.description}</p>
                  </div>
                </div>
                <div class="flex items-center gap-2 sm:gap-3 w-full sm:w-auto justify-end">
                  <a 
                    href={`${basePath}/projects/${project.id}/edit`}
                    class="px-3 py-2 text-sm text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-lg transition-colors"
                  >
                    编辑
                  </a>
                  <button 
                    class="delete-project-btn px-3 py-2 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-lg transition-colors"
                    data-id={project.id}
                    data-name={project.name}
                  >
                    删除
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="text-center py-12 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700">
          <p class="text-slate-500 mb-4">暂无项目</p>
        </div>
      )}
    </div>

    <!-- Workflows Tab -->
    <div id="tab-workflows" class="tab-content hidden">
      <div class="flex justify-end mb-4">
        <button id="add-workflow-btn" class="px-4 py-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white rounded-lg hover:shadow-lg hover:shadow-blue-500/25 transition-all">
          + 添加工作流
        </button>
      </div>
      
      {workflows.length > 0 ? (
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
          <div class="divide-y divide-slate-200 dark:divide-slate-700">
            {workflows.map(workflow => (
              <div class="p-4 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                <div class="flex items-center gap-4 flex-1 min-w-0">
                  <span class="text-3xl">{workflow.icon || '⚡'}</span>
                  <div class="min-w-0">
                    <h3 class="text-base sm:text-lg font-semibold text-slate-800 dark:text-slate-200 truncate">
                      {workflow.name}
                    </h3>
                    <p class="text-sm text-slate-500 truncate hidden sm:block">{workflow.description}</p>
                    <div class="flex flex-wrap gap-1 mt-1">
                      {(workflow.tags || '').split(',').map((tag: string) => (
                        <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 rounded text-xs">
                          {tag.trim()}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-2 sm:gap-3 w-full sm:w-auto justify-end">
                  <a 
                    href={`${basePath}/workflows/${workflow.id}/edit`}
                    class="px-3 py-2 text-sm text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-lg transition-colors"
                  >
                    编辑
                  </a>
                  <button 
                    class="delete-workflow-btn px-3 py-2 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-lg transition-colors"
                    data-id={workflow.id}
                    data-name={workflow.name}
                  >
                    删除
                  </button>
                </div>
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="text-center py-12 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700">
          <p class="text-slate-500 mb-4">暂无工作流</p>
        </div>
      )}
    </div>
  </div>

  <!-- Project Modal -->
  <div id="project-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
      <h2 id="project-modal-title" class="text-xl font-bold text-slate-800 dark:text-slate-200 mb-4">添加项目</h2>
      <form id="project-form" class="space-y-4">
        <input type="hidden" id="project-id" name="id" value="" />
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">图标 (emoji)</label>
          <input type="text" id="project-icon" name="icon" placeholder="📦" class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">项目名称</label>
          <input type="text" id="project-name" name="name" required placeholder="项目名称" class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">描述</label>
          <textarea id="project-description" name="description" rows="2" placeholder="项目描述" class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200 resize-none"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">项目链接</label>
          <input type="url" id="project-url" name="url" placeholder="https://github.com/..." class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="cancel-project" class="flex-1 px-4 py-2 bg-slate-100 dark:bg-slate-600 text-slate-700 dark:text-slate-200 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-500 transition-colors">取消</button>
          <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">保存</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Workflow Modal -->
  <div id="workflow-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
      <h2 id="workflow-modal-title" class="text-xl font-bold text-slate-800 dark:text-slate-200 mb-4">添加工作流</h2>
      <form id="workflow-form" class="space-y-4">
        <input type="hidden" id="workflow-id" name="id" value="" />
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">图标 (emoji)</label>
          <input type="text" id="workflow-icon" name="icon" placeholder="⚡" class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">名称</label>
          <input type="text" id="workflow-name" name="name" required placeholder="工作流名称" class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">描述</label>
          <textarea id="workflow-description" name="description" rows="2" placeholder="工作流描述" class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200 resize-none"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">标签 (逗号分隔)</label>
          <input type="text" id="workflow-tags" name="tags" placeholder="AI, 自动化" class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">链接地址</label>
          <input type="url" id="workflow-url" name="url" placeholder="https://runninghub.example.com/workflow/..." class="w-full px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200" />
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" id="cancel-workflow" class="flex-1 px-4 py-2 bg-slate-100 dark:bg-slate-600 text-slate-700 dark:text-slate-200 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-500 transition-colors">取消</button>
          <button type="submit" class="flex-1 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">保存</button>
        </div>
      </form>
      </div>
    </div>

      <!-- Products Tab -->
    <div id="tab-products" class="tab-content hidden">
      <div class="flex justify-end mb-4">
        <button id="add-product-btn" class="px-4 py-2 bg-gradient-to-r from-blue-600 to-violet-600 text-white rounded-lg hover:shadow-lg hover:shadow-blue-500/25 transition-all">
          + 添加产品
        </button>
      </div>
      
      {products.length > 0 ? (
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
          <div class="divide-y divide-slate-200 dark:divide-slate-700">
            {products.map(product => (
              <div class="p-4 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                <div class="flex items-center gap-4 flex-1 min-w-0">
                  {product.image && (
                    <img src={product.image} alt="" class="w-16 h-12 object-cover rounded-lg flex-shrink-0" />
                  )}
                  <span class="text-2xl">{product.icon || '📦'}</span>
                  <div class="min-w-0 flex-1">
                    <h3 class="text-base sm:text-lg font-semibold text-slate-800 dark:text-slate-200 truncate">{product.name}</h3>
                    <p class="text-sm text-slate-500 truncate hidden sm:block">{product.description}</p>
                  </div>
                </div>
                <div class="flex items-center gap-2 sm:gap-3 w-full sm:w-auto justify-end">
                  <a href={`${basePath}/products/${product.id}/edit`} class="px-3 py-2 text-sm text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-lg transition-colors">编辑</a>
                  <button class="delete-product-btn px-3 py-2 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-lg transition-colors" data-id={product.id} data-name={product.name}>删除</button>
                </div>
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="text-center py-12 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700">
          <p class="text-slate-500 mb-4">暂无产品</p>
        </div>
      )}
    </div>

    <!-- Stats Tab -->
    <div id="tab-stats" class="tab-content hidden">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-gradient-to-br from-blue-500 to-cyan-500 rounded-2xl p-6 text-white shadow-lg">
          <div class="text-sm opacity-80 mb-1">总访问量</div>
          <div id="stat-total" class="text-4xl font-bold">-</div>
          <div class="text-sm opacity-60 mt-2">次</div>
        </div>
        <div class="bg-gradient-to-br from-purple-500 to-pink-500 rounded-2xl p-6 text-white shadow-lg">
          <div class="text-sm opacity-80 mb-1">页面数</div>
          <div id="stat-pages" class="text-4xl font-bold">-</div>
          <div class="text-sm opacity-60 mt-2">个</div>
        </div>
        <div class="bg-gradient-to-br from-amber-500 to-orange-500 rounded-2xl p-6 text-white shadow-lg">
          <div class="text-sm opacity-80 mb-1">平均访问</div>
          <div id="stat-avg" class="text-4xl font-bold">-</div>
          <div class="text-sm opacity-60 mt-2">次/页</div>
        </div>
      </div>
      
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
          <h3 class="font-semibold text-slate-800 dark:text-slate-200">访问排行</h3>
        </div>
        <div id="stats-list" class="divide-y divide-slate-200 dark:divide-slate-700">
          <div class="p-6 text-center text-slate-500">加载中...</div>
        </div>
      </div>
    </div>

    <!-- SMTP Settings Tab -->
    <div id="tab-smtp" class="tab-content hidden">
      <div class="space-y-6">
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-6">
          <h3 class="text-lg font-semibold text-slate-800 dark:text-slate-200 mb-4 flex items-center gap-2">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-pink-500 to-violet-500 flex items-center justify-center text-white text-sm">📧</span>
            SMTP 邮件设置
          </h3>
          
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <input type="checkbox" id="smtp-enabled" class="w-5 h-5 rounded accent-pink-500" />
              <label for="smtp-enabled" class="text-slate-700 dark:text-slate-300">启用邮件通知</label>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-1">SMTP 服务器 *</label>
                <input type="text" id="smtp-host" placeholder="smtp.gmail.com" 
                  class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-pink-500 outline-none" />
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-600 dark:text-slate-400 mb-1">端口 *</label>
                <input type="text" id="smtp-port" placeholder="587" value="587"
                  class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-200 focus:ring-2 focus:ring-pink-500 outline-none" />
              </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
              <div>
